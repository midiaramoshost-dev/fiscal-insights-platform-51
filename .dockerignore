# Dependências (serão instaladas dentro do Docker)
node_modules
npm-debug.log
yarn-error.log

# Git
.git
.gitignore

# Arquivos de ambiente locais (não devem ir para o build)
.env
.env.local
.env.production
.env.*

# Outputs de build local (o Docker gera o próprio dist/)
dist
build

# Arquivos de sistema e IDEs
.DS_Store
Thumbs.db
.vscode
.idea
*.swp
*.swo

# Testes e documentação (opcional, para economizar espaço no contexto de build)
coverage
.nyc_output
__tests__
*.test.ts
*.spec.ts
*.md
!README.md

# GitHub Actions
.github
